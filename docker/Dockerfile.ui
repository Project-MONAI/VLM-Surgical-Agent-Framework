FROM nvcr.io/nvidia/pytorch:25.03-py3

WORKDIR /app

# System deps — invalidated only when base image or Node version changes
RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Python deps
RUN pip install --no-cache-dir tiktoken \
    uvicorn \
    websockets \
    flask \
    fastapi \
    starlette \
    sse_starlette \
    starlette_context \
    elevenlabs \
    openai \
    sentence-transformers

# Pre-download tiktoken encoding data so it works offline
ENV TIKTOKEN_CACHE_DIR=/opt/tiktoken_cache
RUN mkdir -p $TIKTOKEN_CACHE_DIR && \
    python -c "import tiktoken; tiktoken.get_encoding('cl100k_base')"

# npm deps — invalidated only when package.json / package-lock.json change
COPY package.json package-lock.json ./
RUN npm install

# Frontend assets — invalidated when web sources or build config change
COPY postcss.config.js tailwind.config.js vite.config.js ./
COPY web web
RUN npm run build:tailwind

# Application scripts — invalidated when script/config files change
COPY servers/app.py servers/app.py
COPY servers/web_server.py servers/web_server.py
COPY configs configs
COPY agents agents
COPY ehr ehr
COPY utils utils

EXPOSE 8050

CMD ["python", "servers/app.py"]
